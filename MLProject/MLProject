name: Sepsis_ICU_Prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 10
      learning_rate:
        type: float
        default: 0.1
      n_trials:
        type: int
        default: 30
      model_type:
        type: str
        default: "xgboost"
      data_dir:
        type: str
        default: "sepsis_preprocessing"
      output_dir:
        type: str
        default: "./artifacts"
      no_dagshub:
        type: bool
        default: false
      dagshub_username:
        type: str
        default: ""
      dagshub_repo:
        type: str
        default: ""

    command: "python modelling.py --n_estimators {n_estimators} --max_depth {max_depth} --learning_rate {learning_rate} --n_trials {n_trials} --model_type {model_type} --data_dir {data_dir} --output_dir {output_dir} --no_dagshub"

